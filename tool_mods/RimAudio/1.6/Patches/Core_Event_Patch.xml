<?xml version="1.0" encoding="UTF-8"?>
<Patch>

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/WeatherDef[defName="Rain" or defName="FoggyRain"]/modExtensions</xpath>
    <match Class="PatchOperationAdd">
      <xpath>Defs/WeatherDef[defName="Rain" or defName="FoggyRain"]/modExtensions</xpath>
      <value>
        <li Class="RimAudio.ModExtension_Audio">
          <thought>RimAudio_RainSound</thought>
          <loudness>1.0</loudness>
          <outdoorsOnly>true</outdoorsOnly>
        </li>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/WeatherDef[defName="Rain" or defName="FoggyRain"]</xpath>
      <value>
        <modExtensions>
          <li Class="RimAudio.ModExtension_Audio">
            <thought>RimAudio_RainSound</thought>
            <loudness>1.0</loudness>
            <outdoorsOnly>true</outdoorsOnly>
          </li>
        </modExtensions>
      </value>
    </nomatch>
  </Operation>

