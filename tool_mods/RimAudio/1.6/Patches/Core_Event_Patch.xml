      <xpath>Defs/WeatherDef[defName="RainyThunderstorm"]</xpath>
      <value>
        <modExtensions>
          <li Class="RimAudio.ModExtension_Audio">
            <thought>RimAudio_ThunderSound</thought>
            <loudness>1.3</loudness>
            <outdoorsOnly>true</outdoorsOnly>
          </li>
        </modExtensions>
      </value>
    </nomatch>
  </Operation>

