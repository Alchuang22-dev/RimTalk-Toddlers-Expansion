<?xml version="1.0" encoding="UTF-8"?>
<Patch>

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="Campfire"]/modExtensions</xpath>
    <match Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="Campfire"]/modExtensions</xpath>
      <value>
        <li Class="RimAudio.ModExtension_Audio">
          <thought>RimAudio_CampfireCrackle</thought>
          <radius>8</radius>
          <loudness>0.9</loudness>
        </li>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="Campfire"]</xpath>
      <value>
        <modExtensions>
          <li Class="RimAudio.ModExtension_Audio">
            <thought>RimAudio_CampfireCrackle</thought>
            <radius>8</radius>
            <loudness>0.9</loudness>
          </li>
        </modExtensions>
      </value>
    </nomatch>
  </Operation>

